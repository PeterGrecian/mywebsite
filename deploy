#!/bin/bash -ex
# Deploy mywebsite Lambda function

# Bake build_info.py with version, commit, commit time. The Lambda reads
# these constants to render version annotations on /skycam etc.
VERSION=$(cat VERSION 2>/dev/null || echo "unknown")
COMMIT=$(git rev-parse --short HEAD 2>/dev/null || echo "unknown")
COMMIT_TIME=$(git log -1 --format=%cI HEAD 2>/dev/null || echo "unknown")
# Bump deploy counter — independent of git commits. The pet name is seeded
# from "commit#count", so the name changes when EITHER the source commits
# OR the deploy counter changes. Spot stale caches at a glance.
DEPLOY_COUNT=$(( $(cat DEPLOY_COUNT 2>/dev/null || echo 0) + 1 ))
echo "$DEPLOY_COUNT" > DEPLOY_COUNT
# Also pick up gardencam's version/commit so the Timelapse section can
# show *its* build state — the timelapse pipeline lives in that repo.
GC_DIR="$HOME/Berrylands/gardencam"
if [ -d "$GC_DIR/.git" ]; then
  GC_VERSION=$(cat "$GC_DIR/VERSION" 2>/dev/null || echo "unknown")
  GC_COMMIT=$(git -C "$GC_DIR" rev-parse --short HEAD 2>/dev/null || echo "unknown")
  GC_COMMIT_TIME=$(git -C "$GC_DIR" log -1 --format=%cI HEAD 2>/dev/null || echo "unknown")
else
  GC_VERSION="unknown"; GC_COMMIT="unknown"; GC_COMMIT_TIME="unknown"
fi

DEPLOY_TIME=$(date -u +%s)
cat > lambda/build_info.py <<EOF
# Auto-generated by deploy. Do not edit by hand.
VERSION = "$VERSION"
COMMIT = "$COMMIT"
COMMIT_TIME = "$COMMIT_TIME"
DEPLOY_COUNT = $DEPLOY_COUNT
DEPLOY_TIME = $DEPLOY_TIME
GARDENCAM_VERSION = "$GC_VERSION"
GARDENCAM_COMMIT = "$GC_COMMIT"
GARDENCAM_COMMIT_TIME = "$GC_COMMIT_TIME"
EOF
PET_NAME=$(cd lambda && python3 -c "from petname import pet_name; print(pet_name('$COMMIT#$DEPLOY_COUNT'))")
echo "Deploying mywebsite v$VERSION  $COMMIT#$DEPLOY_COUNT  $PET_NAME  $COMMIT_TIME"
echo "         (gardencam v$GC_VERSION  $GC_COMMIT  $GC_COMMIT_TIME)"

# Validate Python syntax
if ! python3 -m py_compile lambda/mywebsite.py; then
  echo "Syntax error — not deploying"
  exit 1
fi
rm -rf __pycache__

# Generate favicon
base64 lambda/tick.png > lambda/favicon.png64

# Generate gitinfo
echo '<link rel="stylesheet" href="styles.css">' > lambda/gitinfo.html
echo '<title>Peter Grecian - Git Info</title>' >> lambda/gitinfo.html
echo '<div style="text-align: center; margin: 1rem;"><a href="contents" style="color: #4a9eff; text-decoration: none;">Home</a></div>' >> lambda/gitinfo.html
origin=$(git remote get-url origin 2>/dev/null || echo "local")
log=$(git log -1 --oneline 2>/dev/null || echo "no commits")
date=$(date)
echo "$origin<br>$log<br>$date<br>" >> lambda/gitinfo.html
commit=$(echo $log | cut -d ' ' -f 1)
echo '<a href="https://github.com/PeterGrecian/mywebsite/commit/'$commit'">https://github.com/PeterGrecian/mywebsite/commit/'$commit'</a>' >> lambda/gitinfo.html
echo '</body></html>' >> lambda/gitinfo.html

# Run local smoke test (must run from lambda/ so relative file opens work)
if ! (cd lambda && python3 mywebsite.py); then
  echo "Smoke test failed — not deploying"
  exit 1
fi

# Package Lambda
cd lambda
zip ../mywebsite.zip *.py *.html *.png64 *.jpg *.txt 2>/dev/null || zip ../mywebsite.zip *.py *.html *.png64 *.txt
zip -r ../mywebsite.zip routes/ templates/ -x '*__pycache__*' 2>/dev/null || true
cd ..

# Upload to Lambda
fn=mywebsite
aws lambda update-function-code --zip-file fileb://$PWD/mywebsite.zip \
  --function-name $fn | grep CodeSize

# Wait for code update to complete before changing configuration
aws lambda wait function-updated --function-name $fn

# Ensure handler is correct (guard against it being changed to cv.lambda_handler etc.)
aws lambda update-function-configuration --function-name $fn \
  --handler mywebsite.lambda_handler | grep Handler
echo "aws logs tail /aws/lambda/$fn --follow"

# Purge cached static routes from Cloudflare edge.
# Uses a scoped API token (Zone.Cache Purge only, scoped to petergrecian.co.uk).
# Disable command tracing here so the token never appears in logs.
set +x
echo "Purging Cloudflare cache..."
CF_TOKEN=$(~/super/bin/secrets get /cloudflare/purge-token 2>/dev/null)
CF_ZONE_ID="322ca2637607726fee0c4975d1aed591"  # petergrecian.co.uk
if [ -n "$CF_TOKEN" ]; then
  curl -s -X POST "https://api.cloudflare.com/client/v4/zones/$CF_ZONE_ID/purge_cache" \
    -H "Authorization: Bearer $CF_TOKEN" -H "Content-Type: application/json" \
    --data '{"purge_everything":true}' \
    | python3 -c "import sys,json; r=json.load(sys.stdin); print('Cache purged (everything)' if r.get('success') else f'Purge failed: {r}')"
else
  echo "WARNING: No Cloudflare purge token — skipping cache purge"
fi
set -x

# Cleanup
rm mywebsite.zip
rm -f lambda/favicon.png64
